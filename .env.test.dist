SHOPWARE_URL=http://localhost
SHOPWARE_STOREFRONT_URL=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
SHOPWARE_ADMIN_USER=admin
SHOPWARE_ADMIN_PASSWORD=
SHOPWARE_STORE_ACCESS_KEY=
SHOPWARE_INTEGRATION_ACCESS_KEY=
SHOPWARE_INTEGRATION_SECRET=
SHOPWARE_SALES_CHANNEL_ID=
SHOPWARE_TEST_PRODUCT_ID=
# ISO code of the billing country for test orders (must be active in Shopware).
# Looked up dynamically -- avoids hardcoding an installation-specific UUID.
SHOPWARE_TEST_COUNTRY_ISO=DE

# --- CQRS read projection + write queue (T13) -----------------------------
# Feature flags (default off → plugin keeps synchronous, DAL-backed behaviour):
ORDER_INTEGRATION_ASYNC_WRITES=false
ORDER_INTEGRATION_PROJECTION_READS=false
# Dedicated read/queue DB (PostgreSQL). Required only when the flags are on.
# Example: pgsql:host=127.0.0.1;port=5433;dbname=order_integration
ORDER_INTEGRATION_DB_DSN=
ORDER_INTEGRATION_DB_USER=order_integration
ORDER_INTEGRATION_DB_PASSWORD=
