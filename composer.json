{
    "name": "scotty42/order-integration",
    "description": "Order Integration API Plugin for Shopware 6",
    "type": "shopware-platform-plugin",
    "license": "LicenseRef-PolyForm-Noncommercial-1.0.0",
    "version": "1.4.0",
    "require": {
        "php": "^8.2",
        "shopware/core": "~6.6.0 || ~6.7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Scotty42\\OrderIntegration\\": "src/Plugin/OrderIntegration/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Scotty42\\OrderIntegration\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:coverage": "phpunit --testsuite=Unit --coverage-text"
    },
    "extra": {
        "shopware-plugin-class": "Scotty42\\OrderIntegration\\OrderIntegrationPlugin",
        "label": {
            "de-DE": "Order Integration API",
            "en-GB": "Order Integration API"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
