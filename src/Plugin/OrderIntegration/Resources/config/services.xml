<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Scotty42\OrderIntegration\Controller\OrderController" public="true">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Validator\QueryValidator"/>
            <argument type="service" id="Scotty42\OrderIntegration\Validator\OrderCreateValidator"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderCreationService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderPatchService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderMapper"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\StateMachineService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\IdempotencyService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Http\EtagComparator"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\CqrsGateway"/>
            <argument type="service" id="order_integration.lock_factory"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Scotty42\OrderIntegration\Controller\StatusController" public="true">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\StateMachineService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderMapper"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\IdempotencyService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Http\EtagComparator"/>
            <argument type="service" id="order_integration.lock_factory"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Scotty42\OrderIntegration\Controller\DeliveryController" public="true">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="order_delivery.repository"/>
            <argument type="service" id="order_address.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\StateMachineService"/>
            <argument type="service" id="Shopware\Core\System\StateMachine\Loader\InitialStateIdLoader"/>
            <argument type="service" id="country.repository"/>
            <argument type="service" id="salutation.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Http\EtagComparator"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="Scotty42\OrderIntegration\Http\EtagComparator"/>

        <service id="Scotty42\OrderIntegration\Service\OrderMapper"/>

        <service id="Scotty42\OrderIntegration\Service\OrderCreationService">
            <argument type="service" id="Shopware\Core\Checkout\Cart\SalesChannel\CartService"/>
            <argument type="service" id="Shopware\Core\Checkout\Cart\Order\OrderPersister"/>
            <argument type="service" id="Shopware\Core\System\SalesChannel\Context\CachedSalesChannelContextFactory"/>
        </service>

        <service id="Scotty42\OrderIntegration\Service\OrderPatchService">
            <argument type="service" id="order.repository"/>
        </service>

        <!-- Dedicated, shared, persistent pool for idempotency records. Must NOT
             be cache.app: that pool can be process-local (APCu) and/or pruned by
             Shopware's cache invalidation on order writes, which would break
             cross-request replay/conflict detection. FilesystemAdapter is shared
             across FPM workers and survives cache:clear. -->
        <service id="order_integration.idempotency_cache" class="Symfony\Component\Cache\Adapter\FilesystemAdapter">
            <argument>order_integration_idempotency</argument>
        </service>

        <service id="Scotty42\OrderIntegration\Idempotency\Psr6IdempotencyStore">
            <argument type="service" id="order_integration.idempotency_cache"/>
        </service>

        <service id="Scotty42\OrderIntegration\Service\IdempotencyService">
            <argument type="service" id="Scotty42\OrderIntegration\Idempotency\Psr6IdempotencyStore"/>
        </service>

        <service id="Scotty42\OrderIntegration\Service\StateMachineService">
            <argument type="service" id="Shopware\Core\System\StateMachine\StateMachineRegistry"/>
        </service>

        <service id="Scotty42\OrderIntegration\Validator\QueryValidator"/>

        <service id="Scotty42\OrderIntegration\Validator\OrderCreateValidator"/>

        <service id="Scotty42\OrderIntegration\EventSubscriber\ExceptionSubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Scotty42\OrderIntegration\Erp\ErpSyncPolicy"/>

        <service id="Scotty42\OrderIntegration\Erp\ErpSyncService">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Erp\ErpSyncPolicy"/>
        </service>

        <service id="Scotty42\OrderIntegration\Controller\ErpSyncController" public="true">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Erp\ErpSyncService"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderMapper"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <!-- Write-lock infrastructure for TOCTOU prevention.
             FlockStore provides per-server file-backed mutexes. For deployments
             that run multiple PHP-FPM hosts, swap the store to
             Symfony\Component\Lock\Store\RedisStore (preferred) or
             Symfony\Component\Lock\Store\DoctrineDbalStore so locks are shared
             across the cluster. symfony/lock ≥6.2 ships with Shopware 6.6+. -->
        <service id="Symfony\Component\Lock\Store\FlockStore">
            <argument>%kernel.cache_dir%/order-integration-locks</argument>
        </service>
        <service id="order_integration.lock_factory" class="Symfony\Component\Lock\LockFactory">
            <argument type="service" id="Symfony\Component\Lock\Store\FlockStore"/>
        </service>

        <!-- CQRS: read projection + write queue (Option C, concept docs/cqrs-write-queue-concept.md) -->
        <service id="Scotty42\OrderIntegration\Cqrs\PdoConnectionProvider">
            <factory class="Scotty42\OrderIntegration\Cqrs\PdoConnectionProvider" method="fromEnv"/>
        </service>

        <service id="Scotty42\OrderIntegration\Cqrs\Write\PdoWriteQueue">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\PdoConnectionProvider"/>
        </service>
        <service id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueInterface"
                 alias="Scotty42\OrderIntegration\Cqrs\Write\PdoWriteQueue"/>

        <service id="Scotty42\OrderIntegration\Cqrs\Read\PdoReadProjection">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\PdoConnectionProvider"/>
        </service>
        <service id="Scotty42\OrderIntegration\Cqrs\Read\ReadProjectionInterface"
                 alias="Scotty42\OrderIntegration\Cqrs\Read\PdoReadProjection"/>

        <service id="Scotty42\OrderIntegration\Cqrs\Write\RetryPolicy"/>
        <service id="Scotty42\OrderIntegration\Cqrs\Write\BackpressurePolicy"/>

        <service id="Scotty42\OrderIntegration\Cqrs\Write\ShopwareCommandHandler">
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderCreationService"/>
        </service>
        <service id="Scotty42\OrderIntegration\Cqrs\Write\CommandHandlerInterface"
                 alias="Scotty42\OrderIntegration\Cqrs\Write\ShopwareCommandHandler"/>

        <service id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueWorker">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueInterface"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\CommandHandlerInterface"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\RetryPolicy"/>
        </service>

        <service id="Scotty42\OrderIntegration\Cqrs\CqrsGateway">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueInterface"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Read\ReadProjectionInterface"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\BackpressurePolicy"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\PdoConnectionProvider"/>
        </service>

        <service id="Scotty42\OrderIntegration\Cqrs\Read\OrderProjectionWriter">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Read\ReadProjectionInterface"/>
            <argument type="service" id="Scotty42\OrderIntegration\Service\OrderMapper"/>
        </service>

        <service id="Scotty42\OrderIntegration\Cqrs\Read\OrderProjectionSubscriber">
            <argument type="service" id="order.repository"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Read\OrderProjectionWriter"/>
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\PdoConnectionProvider"/>
            <argument type="service" id="logger"/>
            <argument type="service" id="order_delivery.repository"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="Scotty42\OrderIntegration\Cqrs\Command\DrainWriteQueueCommand">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueWorker"/>
            <tag name="console.command"/>
        </service>

        <service id="Scotty42\OrderIntegration\Cqrs\Command\PurgeWriteQueueCommand">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueInterface"/>
            <tag name="console.command"/>
        </service>

        <service id="Scotty42\OrderIntegration\Controller\JobController" public="true">
            <argument type="service" id="Scotty42\OrderIntegration\Cqrs\Write\WriteQueueInterface"/>
            <tag name="controller.service_arguments"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

    </services>
</container>
